{
    servers {
        protocols h1 h2
    }
}

# Caddyfile for StreamDrop
# This configuration is optimized for high-throughput streaming bulk file transfers

www.streamdrop.app {
    redir https://streamdrop.app{uri} permanent
}

streamdrop.app {
    encode gzip zstd

    reverse_proxy localhost:3000 {
        # Critical for streaming bulk transfers: Disable periodic flushing.
        # This allows Caddy to batch writes to the network, massively reducing
        # CPU usage and TLS encryption overhead for high-speed transfers.
        flush_interval -1
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        # Disable caching for dynamic/streaming endpoints
        Cache-Control "no-store, no-cache, must-revalidate" {
            /upload/*
            /download/*
            /d/*
            /raw/*
            /stats
            /health
        }
    }

    log {
        output stdout
        format json
    }
}

# Local development configuration
:3001 {
    encode gzip
    reverse_proxy localhost:3000 {
        flush_interval -1
    }
}

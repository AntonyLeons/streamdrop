# Caddyfile for StreamDrop
# This configuration optimizes for streaming file transfers with minimal buffering

www.streamdrop.app {
    redir https://streamdrop.app{uri} permanent
}

streamdrop.app {
    encode gzip zstd

    reverse_proxy localhost:3000 {
        # Critical for streaming: flush immediately, don't buffer
        flush_interval 0
        
        # Optional: Increase buffer sizes for high-throughput transfers
        # buffer_requests 64KB
        # buffer_responses 64KB
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        # Disable caching for dynamic/streaming endpoints
        Cache-Control "no-store, no-cache, must-revalidate" {
            /upload/
            /download/
            /d/
            /raw/
        }
    }

    log {
        output stdout
        format json
    }
}

# Local development configuration
:3001 {
    encode gzip
    reverse_proxy localhost:3000 {
        flush_interval 0
    }
}
